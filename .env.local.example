# Plantilla compartida para el equipo.
# Este archivo SI se versiona en git.
# Copiar como .env.local para uso local (ese NO se versiona).
# Formato: KEY=VALUE (sin comillas salvo que necesites espacios).

# -------- MQTT Bridge --------
MQTT_BROKER=192.168.1.50
MQTT_PORT=1883
MQTT_TOPIC=building/01/home/+/telemetry
EDGE_OUTPUT=telemetry
MQTT_KEEPALIVE=60
LOG_LEVEL=INFO

# -------- Edge Decider --------
ED_IN=input1
ED_OUT=output1
SAMPLE_TICK_SEC=0.2
AGG_PUB_SEC=900
ALARM_CD_SEC=60

# Umbrales recomendados (ajustar segun calibracion real)
# LIGHT_BRIGHT_MAX < LIGHT_AMBIENT_MAX
LIGHT_BRIGHT_MAX=200
LIGHT_AMBIENT_MAX=450

# Temperatura en C
TEMP_LOW=15
TEMP_HIGH=30

# Humedad relativa en %
HUM_LOW=20
HUM_HIGH=80
LOG=INFO

# -------- Arduino (usado por scripts/sync-local-secrets.ps1) --------
WIFI_SSID=CHANGE_ME_SSID
WIFI_PASS=CHANGE_ME_PASSWORD
MQTT_HOST=192.168.1.50
